{#-
  Plane Work Item HTML Template

  Renders a comprehensive, formatted description for Plane work items.
  All values are grounded in factory artifacts via Memory MCP queries.

  Required variables:
    - name: str           (issue title)
    - type: str           (FEATURE|BUG|SKILL|DOCU|INFRA)
    - requirements: list  (requirement strings)
    - acceptance_criteria: list (criteria strings)
    - workflows: list     (workflow slugs from .agent/workflows/)
    - agents: list        (agent identifiers from .agent/agents/)
    - skills: list        (skill names from .agent/skills/)
    - tests: list of dict ({type, script?, command?, expected})

  Optional variables:
    - rules: list         (rule filenames from .agent/rules/)
    - patterns: list      (pattern names from .agent/patterns/)
    - blueprints: list    (blueprint names from .agent/blueprints/)
    - templates: list     (template names from .agent/templates/)
    - knowledge: list of dict ({name, source})
    - scripts: list       (script paths)
    - memory_queries: list (Memory MCP entity names)
    - notes: str          (additional context)
-#}
<h3>📋 Requirements</h3><ul>{% for req in requirements %}<li>{{ req }}</li>{% endfor %}</ul><hr><h3>✅ Acceptance Criteria</h3><ul>{% for ac in acceptance_criteria %}<li>[ ] {{ ac }}</li>{% endfor %}</ul><hr><h3>🏭 Factory Asset Assignment</h3><ul><li><strong>🔄 Workflows:</strong>{% if workflows %} {% for w in workflows %}<code>{{ w }}</code>{% if not loop.last %}, {% endif %}{% endfor %}{% else %} <em>None</em>{% endif %}</li><li><strong>👤 Agents:</strong>{% if agents %} {% for a in agents %}<code>{{ a }}</code>{% if not loop.last %}, {% endif %}{% endfor %}{% else %} <em>None</em>{% endif %}</li><li><strong>🧩 Skills:</strong>{% if skills %} {% for s in skills %}<code>{{ s }}</code>{% if not loop.last %}, {% endif %}{% endfor %}{% else %} <em>None</em>{% endif %}</li>{% if rules %}<li><strong>📏 Rules:</strong> {% for r in rules %}<code>{{ r }}</code>{% if not loop.last %}, {% endif %}{% endfor %}</li>{% endif %}{% if patterns %}<li><strong>📐 Patterns:</strong> {% for p in patterns %}<code>{{ p }}</code>{% if not loop.last %}, {% endif %}{% endfor %}</li>{% endif %}{% if blueprints %}<li><strong>🎨 Blueprints:</strong> {% for b in blueprints %}<code>{{ b }}</code>{% if not loop.last %}, {% endif %}{% endfor %}</li>{% endif %}{% if templates %}<li><strong>📋 Templates:</strong> {% for t in templates %}<code>{{ t }}</code>{% if not loop.last %}, {% endif %}{% endfor %}</li>{% endif %}</ul><hr><h3>🧪 Test Strategy</h3><ul>{% for t in tests %}<li><strong>[{{ t.type | upper }}]</strong> {% if t.script %}<code>{{ t.script }}</code>:{% endif %} {{ t.expected }}</li>{% else %}<li><em>No explicit tests defined.</em></li>{% endfor %}</ul>{% if scripts or knowledge or memory_queries %}<hr><h3>📚 Additional Context</h3><ul>{% if scripts %}<li><strong>Scripts:</strong><ul>{% for s in scripts %}<li><code>{{ s }}</code></li>{% endfor %}</ul></li>{% endif %}{% if knowledge %}<li><strong>Knowledge Sources:</strong><ul>{% for k in knowledge %}<li><code>{{ k.name }}</code> (via <em>{{ k.source }}</em>)</li>{% endfor %}</ul></li>{% endif %}{% if memory_queries %}<li><strong>Memory MCP Queries:</strong><ul>{% for mq in memory_queries %}<li><code>{{ mq }}</code></li>{% endfor %}</ul></li>{% endif %}</ul>{% endif %}{% if notes %}<hr><blockquote><strong>Notes:</strong><br>{{ notes }}</blockquote>{% endif %}
