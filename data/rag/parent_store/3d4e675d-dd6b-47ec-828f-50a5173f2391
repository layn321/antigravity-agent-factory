_name, path, queue):\n    visited.append(path)", "metadata": {"producer": "Antenna House PDF Output Library 6.2.609 (Linux64)", "creator": "AH CSS Formatter V6.2 MR4 for Linux64 : 6.2.6.18551 (2014/09/24 15:00JST)", "creationdate": "2018-03-21T11:42:51+00:00", "source": "D:\\Users\\wpoga\\Documents\\Ebooks\\Antigravity Library\\Web Scraping with Python, 2nd Edition.pdf", "file_path": "D:\\Users\\wpoga\\Documents\\Ebooks\\Antigravity Library\\Web Scraping with Python, 2nd Edition.pdf", "total_pages": 306, "format": "PDF 1.6", "title": "Web Scraping with Python", "author": "Ryan Mitchell", "subject": "", "keywords": "", "moddate": "2018-06-03T19:49:15-08:00", "trapped": "", "modDate": "D:20180603194915-08'00'", "creationDate": "D:20180321114251Z", "page": 261}, "type": "Document"}
