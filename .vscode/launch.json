{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Streamlit: Statistical Dashboard",
            "type": "debugpy",
            "request": "launch",
            "module": "streamlit",
            "args": [
                "run",
                "${workspaceFolder}/projects/statistical_dashboards/app.py"
            ],
            "jinja": true,
            "python": "D:\\Anaconda\\envs\\cursor-factory\\python.exe",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "console": "integratedTerminal"
        },
        {
            "name": "Streamlit: RAG Knowledge Explorer",
            "type": "debugpy",
            "request": "launch",
            "module": "streamlit",
            "args": [
                "run",
                "${workspaceFolder}/projects/rag_knowledge_explorer/app.py"
            ],
            "jinja": true,
            "python": "D:\\Anaconda\\envs\\cursor-factory\\python.exe",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            },
            "console": "integratedTerminal"
        },
        {
            "name": "Python: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "python": "D:\\Anaconda\\envs\\cursor-factory\\python.exe",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        }
    ]
}
